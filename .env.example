# PostgreSQL connection string. Local dev: a local Postgres or a hosted dev
# branch (Neon/Supabase free tier). Production: set this in the Vercel dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
# Generate with: openssl rand -base64 32  (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
NEXTAUTH_SECRET="change-me"
# Your deployed origin, e.g. https://your-app.vercel.app  (locally: http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# Anthropic API key — used by staff "Generate with AI" in the question bank.
# Get one at https://console.anthropic.com/. Leave blank to disable AI generation.
ANTHROPIC_API_KEY=""
